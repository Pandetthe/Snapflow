{
  "categories": [
    {
      "title": "🚀 Features",
      "labels": ["feature", "feat"],
      "prefix": "feat:"
    },
    {
      "title": "🐛 Bug Fixes",
      "labels": ["bug", "fix"],
      "prefix": "fix:"
    },
    {
      "title": "🧱 Structural Changes",
      "labels": ["refactor", "build", "ci"],
      "prefix": "refactor:"
    },
    {
      "title": "🧪 Tests",
      "labels": ["test"],
      "prefix": "test:"
    },
    {
      "title": "📝 Documentation",
      "labels": ["documentation", "docs"],
      "prefix": "docs:"
    },
    {
      "title": "🧹 Chores",
      "labels": ["chore"],
      "prefix": "chore:"
    },
    {
      "title": "⚡ Performance",
      "labels": ["performance", "perf"],
      "prefix": "perf:"
    }
  ],
  "ignore_labels": [
    "ignore"
  ],
  "sort": "ASC",
  "template": "${{CHANGELOG}}\n\n<details>\n<summary>Full list of changes</summary>\n${{UNCATEGORIZED}}\n</details>",
  "pr_template": "- ${{TITLE}} #${{NUMBER}}",
  "commit_template": "- ${{MESSAGE}}",
  "empty_template": "- No notable changes in this release.",
  "label_extractor": [
    {
      "pattern": "^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(?:\\((.*)\\))?!?: (.*)$",
      "target": "$1"
    }
  ]
}
